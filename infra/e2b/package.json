{
  "name": "spiderweb-e2b",
  "version": "1.0.0",
  "description": "E2B sandbox integration for Spiderweb",
  "main": "dist/e2b-client.js",
  "types": "dist/e2b-client.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:e2b": "jest --testPathPattern=e2b"
  },
  "keywords": [
    "e2b",
    "sandbox",
    "security",
    "spiderweb"
  ],
  "author": "Spiderweb Team",
  "license": "MIT",
  "dependencies": {
    "@e2b/sdk": "^0.1.0",
    "@trigger.dev/sdk": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^18.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^4.9.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ]
  }
}